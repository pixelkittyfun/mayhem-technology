  ;(function () {
    const banner = document.getElementById("axol-consent-banner")
    if (!banner) return
    function show() {
      banner.style.display = ""
      banner.setAttribute("aria-hidden", "false")
    }
    function hide() {
      banner.style.display = "none"
      banner.setAttribute("aria-hidden", "true")
    }
    if (!localStorage.getItem("axol-consent")) show()
    function dismiss(value) {
      localStorage.setItem("axol-consent", value)
      if (value === "granted") {
        // Reload so Partytown's DOMContentLoaded scan picks up the Hotjar
        // script tag injected by the analytics loader in Layout.astro.
        location.reload()
        return
      }
      hide()
    }
    document
      .getElementById("axol-consent-accept")
      ?.addEventListener("click", () => dismiss("granted"))
    document
      .getElementById("axol-consent-decline")
      ?.addEventListener("click", () => dismiss("denied"))
  })()
